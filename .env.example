# ==================================================
# WealthPilot — Environment Variables
# Copy this to .env and fill in your values
# ==================================================

# Flask Secret Key (CHANGE THIS in production!)
SECRET_KEY=your-secret-key-here-change-me

# Database URL (SQLite default, use PostgreSQL for production)
# DATABASE_URL=sqlite:///Vnit.db
# DATABASE_URL=postgresql://user:password@host:5432/wealthpilot

# App Port
PORT=7777

# Debug mode (set to false in production)
FLASK_DEBUG=false

# Admin Credentials (CHANGE THESE in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_FULL_NAME=Admin Name

# SMTP / Email Configuration (for OTP verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# Session idle timeout in seconds (default: 1800 = 30 minutes)
SESSION_IDLE_TIMEOUT=1800

# Flask environment (set to 'production' for secure cookies & HSTS)
FLASK_ENV=production

# Optional: Database password
DB_PASSWORD=
